{
  "type": "prepare_env",
  "steps": [
    {
      "action": "detect",
      "target_image": "tag_link_icon.png",
      "is_need_click": true,
      "description": "判断点击 TAG 图标"
    },
    {
      "action": "click",
      "description": "点击 TAG 图标",
      "click_x": -1,
      "click_y": -1
    },
    {
      "action": "detect",
      "target_image": "wps_link_icon.png",
      "is_need_click": true,
      "description": "判断点击 WPS 图标"
    },
    {
      "action": "delay",
      "delay": 30,
      "description": "等待 进入WPS页面"
    },
    {
      "action": "detect_arr_img",
      "target_image_arr": ["wps_create_file.png"],
      "jump_step_num": [2],
      "is_need_click": false,
      "is_select_all": false,
      "image_arr_index": 300,
      "description": "判断点击 新建 按钮"
    },
    {
      "action": "is_first_excel",
      "jump_step_num": [1, 13],
      "description": "判断 是否是第一个excel表"
    },
    {
      "action": "detect",
      "target_image": "wps_create_file.png",
      "is_need_click": true,
      "description": "判断点击 新建 按钮"
    },
    {
      "action": "detect",
      "target_image": "wps_create_table.png",
      "is_need_click": true,
      "description": "判断点击 新建表格 按钮"
    },
    {
      "action": "delay",
      "delay": 6,
      "description": "等待 进入WPS新建表格页面"
    },
    {
      "action": "detect",
      "target_image": "wps_create_icon.png",
      "is_need_click": true,
      "description": "判断点击 新建表格加号 按钮"
    },
    {
      "action": "detect",
      "target_image": "wps_file_icon.png",
      "is_need_click": true,
      "description": "判断点击 文件 图标"
    },
    {
      "action": "detect",
      "target_image": "save_file_icon.png",
      "is_need_click": true,
      "description": "判断点击 保存文件 图标"
    },
    {
      "action": "delay",
      "delay": 1,
      "description": "等待 文件名称输入 弹出"
    },
    {
      "action": "write_current_day",
      "description": "获取当前的日期yyyy-MM-dd并存入extra"
    },
    {
      "action": "delay",
      "delay": 5,
      "description": "等待 当前日期输入"
    },
    {
      "action": "detect",
      "target_image": "save_file_name_btn.png",
      "is_need_click": true,
      "description": "判断点击 确定 按钮"
    },
    {
      "action": "delay",
      "delay": 5,
      "description": "等待 保存文件成功"
    },
    {
      "action": "detect",
      "target_image": "wps_link_activate_icon.png",
      "is_need_click": true,
      "description": "判断点击 WPS激活 图标"
    },
    {
      "action": "delay",
      "delay": 5,
      "description": "等待 文件列表正常展示"
    },
    {
      "action": "click",
      "description": "单击 已存在的WPS文件 图标",
      "click_x": 442,
      "click_y": 328
    },
    {
      "action": "delay",
      "delay": 30,
      "description": "等待 文件打开"
    },
    {
      "action": "detect_arr_img",
      "target_image_arr": ["data.png"],
      "jump_step_num": [2],
      "is_need_click": true,
      "is_select_all": false,
      "image_arr_index": 400,
      "description": "判断 数据 图标"
    },
    {
      "action": "delay",
      "delay": 8,
      "description": "等待 文件切换到 数据选中"
    },
    {
      "action": "detect",
      "target_image": "wps_link_activate_icon.png",
      "is_need_click": true,
      "description": "判断点击 WPS激活 图标"
    }
  ]
}
