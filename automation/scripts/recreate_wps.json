    },
    {
      "action": "delay",
      "delay": 5,
      "description": "等待 当前日期输入"
    },
    {
      "action": "detect",
      "target_image": "save_file_name_btn.png",
      "is_need_click": true,
      "description": "判断点击 确定 按钮"
    },
    {
      "action": "delay",
      "delay": 5,
      "description": "等待 保存文件成功"
    }
